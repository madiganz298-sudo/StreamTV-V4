<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:focusable="true"
    android:clickable="true"
    android:background="?android:attr/selectableItemBackground">

    <!-- ImageView Channel Logo -->
    <ImageView
        android:id="@+id/ivChannelLogo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_m4di_ucih4_tv"
        android:contentDescription="Channel Logo" />

    <!-- Channel Name and Badges Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvChannelName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Channel Name"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical">

            <!-- EVENT Badge (visibility GONE by default) -->
            <TextView
                android:id="@+id/badgeEvent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/event_badge"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@color/badge_event"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!-- LIVE NOW Badge (visibility GONE by default) -->
            <TextView
                android:id="@+id/badgeLiveNow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/live_now_badge"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@color/badge_live"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

    <!-- Vertical line separator at far right -->
    <View
        android:layout_width="2dp"
        android:layout_height="32dp"
        android:background="@color/accent"
        android:layout_marginStart="8dp" />

</LinearLayout>
